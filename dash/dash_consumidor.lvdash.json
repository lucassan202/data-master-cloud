{
  "datasets": [
    {
      "name": "ds_reclamacao",
      "displayName": "Reclamações Top 10",
      "queryLines": [
        "SELECT \n",
        "  case when trim(nomefantasia) in ('Banco do Brasil' , 'Banco do Nordeste')\n",
        "  then nomefantasia\n",
        "  else trim(replace(nomefantasia, 'Banco', '')) \n",
        "  end AS Banco,  \n",
        "  qtdreclamcoes AS Qtd_Reclamacoes,\n",
        "  datrefcarga AS Ano_Mes\n",
        "FROM g_consumidor.reclamacaotopten\n"
      ]
    },
    {
      "name": "ds_mediaresposta",
      "displayName": "Média Tempo Resposta",
      "queryLines": [
        "SELECT \n",
        "  case when trim(nomefantasia) in ('Banco do Brasil' , 'Banco do Nordeste')\n",
        "  then nomefantasia\n",
        "  else trim(replace(nomefantasia, 'Banco', '')) \n",
        "  end AS Banco,  \n",
        "  mediaRespostaDias AS Media_Resposta_Dias,\n",
        "  datrefcarga AS Ano_Mes\n",
        "FROM g_consumidor.mediaresposta\n"
      ]
    },
    {
      "name": "ds_mediaavaliacao",
      "displayName": "Média Avaliação",
      "queryLines": [
        "SELECT \n",
        "  case when trim(nomefantasia) in ('Banco do Brasil' , 'Banco do Nordeste')\n",
        "  then nomefantasia\n",
        "  else trim(replace(nomefantasia, 'Banco', '')) \n",
        "  end AS Banco,  \n",
        "  mediaAvaliacao AS Media_Avaliacao,\n",
        "  datrefcarga AS Ano_Mes\n",
        "FROM g_consumidor.mediaavaliacao\n"
      ]
    },
    {
      "name": "ds_reclamacaouf",
      "displayName": "Reclamações por UF",
      "queryLines": [
        "SELECT \n",
        "  case when trim(nomefantasia) in ('Banco do Brasil' , 'Banco do Nordeste')\n",
        "  then nomefantasia\n",
        "  else trim(replace(nomefantasia, 'Banco', '')) \n",
        "  end AS Banco,  \n",
        "  trim(replace(uf, 'Brasil - ', '')) AS UF,\n",
        "  qtdReclamcoesUf AS Qtd_Reclamacoes_UF,\n",
        "  datrefcarga AS Ano_Mes\n",
        "FROM g_consumidor.reclamacaouf\n"
      ]
    }
  ],
