{
  "datasets": [
    {
      "name": "ds_macro_categoria",
      "displayName": "Macro Categoria IA",
      "queryLines": [
        "SELECT\n",
        "  macro_categoria AS Macro_Categoria,\n",
        "  dataocorrido AS Data_Ocorrido,\n",
        "  qtd AS Qtd\n",
        "FROM g_consumidor.ai_macro_categoria\n"
      ]
    },
    {
      "name": "ds_nota",
      "displayName": "Nota IA",
      "queryLines": [
        "SELECT\n",
        "  nota AS Nota,\n",
        "  dataocorrido AS Data_Ocorrido,\n",
        "  qtd AS Qtd,\n",
        "  CAST(nota AS INT) * qtd AS Nota_Ponderada\n",
        "FROM g_consumidor.ai_nota\n",
        "WHERE nota <> '' AND nota REGEXP '^[0-9]+$'\n"
      ]
    },
    {
      "name": "ds_status",
      "displayName": "Status IA",
      "queryLines": [
        "SELECT\n",
        "  status AS Status,\n",
        "  dataocorrido AS Data_Ocorrido,\n",
        "  qtd AS Qtd\n",
        "FROM g_consumidor.ai_status\n"
      ]
    }
  ],
