        {
          "widget": {
            "name": "filter_dataocorrido",
            "queries": [
              {
                "name": "filter_ds_macro_categoria_Data_Ocorrido",
                "query": {
                  "datasetName": "ds_macro_categoria",
                  "fields": [
                    {
                      "name": "Data_Ocorrido",
                      "expression": "`Data_Ocorrido`"
                    },
                    {
                      "name": "Data_Ocorrido_associativity",
                      "expression": "COUNT_IF(`associative_filter_predicate_group`)"
                    }
                  ],
                  "disaggregated": false
                }
              },
              {
                "name": "filter_ds_nota_Data_Ocorrido",
